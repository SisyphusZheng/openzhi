{
  "$schema": "https://deno.land/x/deno/cli/schemas/config-file.v1.json",
  "workspace": [
    "./packages/kiss-core",
    "./packages/kiss-rpc",
    "./packages/kiss-ui",
    "./examples/poc",
    "./examples/minimal-blog",
    "./examples/fullstack",
    "./docs"
  ],
  "imports": {
    "magic-string": "npm:magic-string@^0.30.0",
    "compare-versions": "npm:compare-versions@^6.0.0",
    "@microsoft/api-extractor": "npm:@microsoft/api-extractor@^7.58.0",
    "@vue/language-core": "npm:@vue/language-core@^2.2.0",
    "@volar/typescript": "npm:@volar/typescript@^2.4.0",
    "@rollup/pluginutils": "npm:@rollup/pluginutils@^5.3.0",
    "local-pkg": "npm:local-pkg@^1.1.0",
    "debug": "npm:debug@^4.4.0",
    "kolorist": "npm:kolorist@^1.8.0",
    "typescript": "npm:typescript@^5.9.0"
  },
  "tasks": {
    "dev": "cd examples/poc && deno task dev",
    "build:core": "cd packages/kiss-core && deno task build",
    "build:rpc": "cd packages/kiss-rpc && deno task build",
    "build:ui": "cd packages/kiss-ui && deno task build",
    "build": "deno task build:rpc && deno task build:core && deno task build:ui",
    "docs:dev": "cd docs && deno task dev",
    "docs:build": "cd docs && deno task build",
    "docs:preview": "cd docs && deno task preview",
    "publish:core": "cd packages/kiss-core && deno publish --allow-dirty",
    "publish:rpc": "cd packages/kiss-rpc && deno publish --allow-dirty",
    "publish:ui": "cd packages/kiss-ui && deno publish --allow-dirty",
    "publish": "deno task publish:rpc && deno task publish:ui && deno task publish:core",
    "test": "deno test --allow-read --allow-write --allow-env --allow-net",
    "test:watch": "deno test --allow-read --allow-write --allow-env --allow-net --watch",
    "typecheck": "deno check **/*.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "clean": "rm -rf packages/*/dist packages/*/.tsbuildinfo"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true,
    "proseWrap": "preserve"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "exclude": ["no-sloppy-imports"]
    }
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "deno.ns"],
    "strict": true,
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "**/dist/**",
    "**/node_modules/**",
    ".deno"
  ]
}
