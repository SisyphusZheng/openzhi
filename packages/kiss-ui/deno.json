{
  "name": "@kissjs/ui",
  "version": "0.1.4",
  "exports": {
    ".": "./src/index.ts",
    "./kiss-button": "./src/kiss-button.ts",
    "./kiss-card": "./src/kiss-card.ts",
    "./kiss-input": "./src/kiss-input.ts",
    "./kiss-code-block": "./src/kiss-code-block.ts",
    "./kiss-layout": "./src/kiss-layout.ts",
    "./design-tokens": "./src/design-tokens.ts"
  },
  "tasks": {
    "build": "deno run -A npm:vite build --config vite.config.build.ts",
    "dev": "deno run -A npm:vite build --config vite.config.build.ts --watch"
  },
  "compilerOptions": {
    "skipLibCheck": true
  },
  "imports": {
    "lit": "npm:lit@^3.2.0"
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
