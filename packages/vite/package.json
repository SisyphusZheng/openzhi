{
  "name": "@hvl/vite",
  "version": "0.1.0",
  "description": "HVL core Vite plugin - Hono + Vite + Lit fullstack framework",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "@hono/zod-validator": "^0.4.0",
    "@lit-labs/ssr": "^1.0.0",
    "@lit-labs/ssr-client": "^1.0.0",
    "lit": "^3.2.0",
    "zod": "^3.24.0",
    "connect": "^3.7.0",
    "picocolors": "^1.1.0"
  },
  "peerDependencies": {
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "vite": "^6.3.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  }
}
