{
  "name": "@hvl/vite",
  "version": "0.1.0",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client/index.ts"
  },
  "tasks": {
    "build": "deno run -A npm:tsup",
    "dev": "deno run -A npm:tsup --watch",
    "test": "deno test --allow-read --allow-write --allow-env --allow-net __tests__/"
  },
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "declarationDir": "./dist"
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
