{
  "name": "hvl-framework",
  "private": true,
  "version": "0.0.0",
  "description": "HVL - Hono + Vite + Lit Fullstack Framework",
  "scripts": {
    "dev": "pnpm -C examples/poc dev",
    "build": "pnpm -C packages/vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint packages/*/src --ext .ts",
    "clean": "rimraf packages/*/dist packages/*/.tsbuildinfo"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "rimraf": "^6.0.0"
  }
}
